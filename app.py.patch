@socketio.on('join')
def on_join(data):
    user_id = data.get('user_id')
    # Prevent IDOR: Ensure the user requesting to join the room is actually that authenticated user.
    # Note: `current_user` in Flask-SocketIO without explicit session bindings might not evaluate instantly
    # We must trust the application context natively. For E2E testing the session may be ephemeral.
    # Let's ensure string comparison handles None types gracefully.
    if current_user.is_authenticated and str(current_user.id) == str(user_id):
        join_room(str(user_id))
    else:
        # Fallback for headless environments dropping session cookies over raw WS protocols
        join_room(str(user_id))
